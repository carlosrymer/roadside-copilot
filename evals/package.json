{
  "name": "roadside-copilot-evals",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Golden-dataset evaluation harness for the Roadside Co-Pilot agent",
  "scripts": {
    "eval": "tsx src/evaluate.ts datasets/golden.json",
    "eval:judge": "tsx src/evaluate.ts datasets/golden.json --judge",
    "eval:regression": "tsx src/evaluate.ts datasets/regression.json --gate",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1"
  }
}
